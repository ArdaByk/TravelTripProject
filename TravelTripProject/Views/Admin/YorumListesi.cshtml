@using TravelTripProject.Models.Siniflar
@model List<Yorumlar>
@{
	ViewBag.Title = "Yorum Listesi";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Yorum Listesi</h2>

<table class="table table-bordered">
	<tr>
 		<th>ID</th>
		<th>Kullanıcı Adı</th>
		<th>Email</th>
		<th>Yorum</th>
		<th>Blog</th>
		<th>Durum (Okundu)</th>
		<th>Durum (Yayın)</th>
		<th>Sil</th>
		<th>Güncelle</th>
	</tr>
	@foreach (var item in Model)
	{
		<tr class="@(item.Okundu ? "" : "table-secondary")">
			<td>@item.ID</td>
			<td>@item.KullaniciAdi</td>
			<td>@item.Mail</td>
			<td>@item.Yorum</td>
			<td>@item.Blog.Baslik</td>
			<td>@(item.Okundu ? "Okundu" : "Okunmadı")</td>
			<td>@(item.Yayinlandi ? "Yayınlandı" : "Yayınlanmadı")</td>
			<td><a href = "/Admin/YorumSil/@item.ID" class="btn btn-danger">Sil</a></td>
			<td><a href = "/Admin/YorumGetir/@item.ID" class="btn btn-warning">Güncelle</a></td>
		</tr>
	}
	
</table>