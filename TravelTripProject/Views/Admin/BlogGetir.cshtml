@model TravelTripProject.Models.Siniflar.Blog

@{
	ViewBag.Title = "BlogGetir";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Blog Güncelleme Sayfası</h2>
<br />

@using (Html.BeginForm("BlogGuncelle", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @Html.LabelFor(x => x.ID)
    @Html.TextBoxFor(x => x.ID, new { @class = "form-control", @readonly = "readonly" })
    <br />

    @Html.LabelFor(x => x.Baslik)
    @Html.TextBoxFor(x => x.Baslik, new { @class = "form-control" })
    @Html.ValidationMessageFor(x => x.Baslik)
    <br />

    @Html.LabelFor(x => x.Tarih)
    @Html.TextBoxFor(x => x.Tarih, new { @class = "form-control" })
    @Html.ValidationMessageFor(x => x.Tarih)
    <br />

    @Html.LabelFor(x => x.BlogImage)
    @Html.TextBoxFor(x => x.BlogImage, new { @class = "form-control", type = "text" })
    @Html.ValidationMessageFor(x => x.BlogImage)
    <br />

    @Html.LabelFor(x => x.Aciklama)
    @Html.TextAreaFor(x => x.Aciklama, 15, 1, new { @class = "form-control" })
    @Html.ValidationMessageFor(x => x.Aciklama)
    <br />

    @Html.LabelFor(x => x.BlogDurum)
    @Html.DropDownListFor(x => x.BlogDurum, new List<SelectListItem>
    {
        new SelectListItem { Text = "Yayınlandı", Value = "1" },
        new SelectListItem { Text = "Yayınlanmadı", Value = "0" }
    }, new { @class = "form-control" })
    <br />

    <button type="submit" class="btn btn-primary">Güncelle</button>
}