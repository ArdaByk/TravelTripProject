@model TravelTripProject.Models.Siniflar.Blog
@{
	ViewBag.Title = "Yeni Blog";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Yeni Blog Ekleme</h2>
<br />
<form class="form-group"method="post">
	@Html.LabelFor(x => x.Baslik)
	@Html.TextBoxFor(x => x.Baslik, new {@class="form-control"} )
	<br />
	@Html.LabelFor(x => x.Tarih)
	@Html.TextBoxFor(x => x.Tarih, new { @class = "form-control" })
	<br />
	@Html.LabelFor(x => x.BlogImage)
	@Html.TextBoxFor(x => x.BlogImage, new { @class = "form-control" })
	<br />
	@Html.LabelFor(x => x.Aciklama)
	@Html.TextAreaFor(x => x.Aciklama, new { @class = "form-control" })
	<br />
	@Html.LabelFor(x => x.BlogDurum)
	<select name="BlogDurum" class="form-control">
		<option value="1">Yayınlandı</option>
		<option value="0">Yayınlanmadı</option>
	</select>
	<br />
	<button class="btn btn-primary">Blog Ekle</button>
</form>